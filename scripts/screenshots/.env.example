# DevOps Loop credentials for Playwright screenshot automation
# Copy this file to scripts/screenshots/.env and fill in real values.
# .env is gitignored — never commit credentials.

LOOP_URL=https://platform-staging.us-east.containers.appdomain.cloud/automation
LOOP_TEAMSPACE=DEMOZ
LOOP_LOOP=Bike
LOOP_USER=your-name
LOOP_PASS=your-password
